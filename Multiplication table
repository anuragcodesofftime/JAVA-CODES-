
import java.util.*;
class Main {
    public static void main(String[] args) {
        System.out.println("Enter a number of which the table you want");
        Scanner sc = new Scanner(System.in);
        int number1 = sc.nextInt();
        for(int i = 1;i<=10;i++){
            int result = number1*i;
            System.out.println(number1+" * "+i+" = "+result);
        }
        
    }
}
